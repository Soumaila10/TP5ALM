# ============================================================
# FIFA Ticketing Hub 2026 — Variables d'environnement (exemple)
# Copier ce fichier en .env (backend) et remplir les valeurs.
# Ne JAMAIS committer le .env réel.
# ============================================================

# --- Azure Cosmos DB (API MongoDB) ---
COSMOS_CONNECTION_STRING=
COSMOS_DB_NAME=fifa-ticketing

# --- Upstash Redis ---
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# --- JWT ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# --- Stripe (sandbox uniquement) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Email (Nodemailer) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Azure Blob Storage ---
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=tickets

# --- Azure Application Insights ---
APPLICATIONINSIGHTS_CONNECTION_STRING=

# --- App ---
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
